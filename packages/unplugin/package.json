{
    "name": "env-attr-cleaner",
    "version": "1.0.1",
    "description": "Universal plugin to strip data-* attributes from production builds",
    "author": "techmefr",
    "license": "MIT",
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "keywords": [
        "unplugin",
        "vite",
        "webpack",
        "rollup",
        "esbuild",
        "nuxt",
        "nextjs",
        "data-attributes",
        "testing",
        "e2e",
        "playwright",
        "cypress"
    ],
    "homepage": "https://github.com/techmefr/env-attr-cleaner/tree/main/packages/unplugin#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/techmefr/env-attr-cleaner.git",
        "directory": "packages/unplugin"
    },
    "bugs": {
        "url": "https://github.com/techmefr/env-attr-cleaner/issues"
    },
    "scripts": {
        "build": "unbuild",
        "test": "vitest run",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "unplugin": "^2.0.0"
    },
    "peerDependencies": {
        "vite": ">=4.0.0",
        "webpack": "^4.0.0 || ^5.0.0",
        "next": "^13.0.0 || ^14.0.0 || ^15.0.0"
    },
    "peerDependenciesMeta": {
        "vite": {
            "optional": true
        },
        "webpack": {
            "optional": true
        },
        "next": {
            "optional": true
        }
    },
    "devDependencies": {
        "unbuild": "^3.0.0",
        "vite": "^5.4.21",
        "vitest": "^1.6.0",
        "typescript": "^5.3.3"
    }
}
